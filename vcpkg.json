{
  "name": "xdelta",
  "version": "3.1.1",
  "description": "Xdelta: a binary diff, differential compression tools",
  "homepage": "http://xdelta.org/",
  "license": "Apache-2.0",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    {
      "name": "liblzma",
      "default-features": [],
      "$comment": "Optional dependency, controlled by XDELTA_ENABLE_LZMA"
    }
  ],
  "features": {
    "tools": {
      "description": "Build xdelta3 command-line tools"
    },
    "tests": {
      "description": "Build xdelta3 tests"
    }
  },
  "default-features": [
    "tools"
  ]
}
